# Copia questo file in `.env.local` e compila con i tuoi valori reali.
# `.env.local` è nel .gitignore e non viene mai committato.

# URL pubblico del progetto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chiave anon (publishable) — pubblica, sicura, va bene esporla al browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxx

# Chiave service_role — SEGRETA. Bypassa RLS. Solo server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Password per l'area /admin (scegline una forte)
ADMIN_PASSWORD=cambia-questa-password

# API key di Google AI Studio per la chat /chat
# Ottenibile gratis (senza carta) su https://aistudio.google.com/app/apikey
# Free tier: Gemini 3.1 Flash-Lite con 1.500 richieste/giorno (maggio 2026)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
